# Yummy Wellness Tracker — environment variables
#
# Copy this file to .env and fill in your values.
# Never commit .env to git.
#
# Required secrets (set these in GitHub → Settings → Secrets → Actions):
#
#   ANTHROPIC_API_KEY  — your Claude API key (sk-ant-...)
#                        https://console.anthropic.com/
#
#   YOUTUBE_API_KEY    — free YouTube Data API v3 key
#                        https://console.cloud.google.com/
#                        Enable: YouTube Data API v3
#                        Free tier: 10,000 units/day (script uses ~500/day)
#
# No other keys are needed:
#   Reddit   — public JSON feed, no key
#   GDELT    — free open API, no key
#   WHO/CDC/NHS RSS — public feeds, no key
#   ipapi.co — free IP geolocation, no key

ANTHROPIC_API_KEY=sk-ant-...
YOUTUBE_API_KEY=AIza...
